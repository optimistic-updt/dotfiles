{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git rev-parse HEAD && git branch --show-current && basename $(git rev-parse --show-toplevel))"
    ]
  },
  "model": "claude-fable-5[1m]",
  "statusLine": {
    "type": "command",
    "command": "/Users/kevin/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "trace-claude-code@braintrust-claude-plugin": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754099816135
  }
}
